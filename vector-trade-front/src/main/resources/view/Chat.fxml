<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.2-ea"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="cl.vc.blotter.controller.ChatController">
    <top>
        <HBox spacing="10" alignment="CENTER_LEFT" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>
            <Label text="Estado"/>
            <Label fx:id="lblChatState" text="CHAT: OFF"/>
            <Label text="|"/>
            <Label text="Conversación:"/>
            <Label fx:id="lblActiveUser" text="(sin seleccionar)"/>
        </HBox>
    </top>

    <left>
        <VBox spacing="8" prefWidth="240" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="10" right="8" bottom="10" left="10"/>
            </padding>
            <Label text="Usuarios"/>
            <HBox spacing="6">
                <TextField fx:id="txtNewUser" promptText="Agregar usuario" HBox.hgrow="ALWAYS"/>
                <Button text="+" onAction="#addUser"/>
            </HBox>
            <ListView fx:id="usersListView" VBox.vgrow="ALWAYS"/>
        </VBox>
    </left>

    <center>
        <ListView fx:id="chatListView" VBox.vgrow="ALWAYS"/>
    </center>

    <bottom>
        <VBox spacing="8" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>
            <HBox spacing="6" alignment="CENTER_LEFT">
                <Button fx:id="btnEmojiGrin" text="😀" onAction="#insertEmoji" style="-fx-font-family: 'Segoe UI Emoji'; -fx-font-size: 16px;"/>
                <Button fx:id="btnEmojiSmile" text="😃" onAction="#insertEmoji" style="-fx-font-family: 'Segoe UI Emoji'; -fx-font-size: 16px;"/>
                <Button fx:id="btnEmojiBlush" text="😊" onAction="#insertEmoji" style="-fx-font-family: 'Segoe UI Emoji'; -fx-font-size: 16px;"/>
                <Button fx:id="btnEmojiWink" text="😉" onAction="#insertEmoji" style="-fx-font-family: 'Segoe UI Emoji'; -fx-font-size: 16px;"/>
                <Button fx:id="btnEmojiTongue" text="😜" onAction="#insertEmoji" style="-fx-font-family: 'Segoe UI Emoji'; -fx-font-size: 16px;"/>
                <Button fx:id="btnEmojiThumbsup" text="👍" onAction="#insertEmoji" style="-fx-font-family: 'Segoe UI Emoji'; -fx-font-size: 16px;"/>
                <Button fx:id="btnEmojiThumbsdown" text="👎" onAction="#insertEmoji" style="-fx-font-family: 'Segoe UI Emoji'; -fx-font-size: 16px;"/>
                <Button fx:id="btnEmojiClap" text="👏" onAction="#insertEmoji" style="-fx-font-family: 'Segoe UI Emoji'; -fx-font-size: 16px;"/>
                <Button fx:id="btnEmojiFire" text="🔥" onAction="#insertEmoji" style="-fx-font-family: 'Segoe UI Emoji'; -fx-font-size: 16px;"/>
                <Button fx:id="btnEmojiHeart" text="❤️" onAction="#insertEmoji" style="-fx-font-family: 'Segoe UI Emoji'; -fx-font-size: 16px;"/>
            </HBox>
            <HBox spacing="10">
                <TextField fx:id="txtMessage" promptText="Escribe un mensaje y presiona Enter" HBox.hgrow="ALWAYS"/>
                <Button fx:id="btnSend" text="Enviar" onAction="#sendMessage"/>
            </HBox>
        </VBox>
    </bottom>
</BorderPane>
