<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<AnchorPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/17.0.2-ea"
            fx:controller="cl.vc.blotter.controller.PositionSimultaneasController">
    <children>
        <VBox spacing="5" styleClass="black-hbox" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
              AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <HBox spacing="5" minHeight="30" minWidth="500" maxWidth="1000" alignment="BASELINE_LEFT">
                    <ButtonBar maxHeight="30" prefHeight="30" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0"
                               HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">
                        <buttons>
                            <Label alignment="BASELINE_RIGHT">Cuenta</Label>
                            <TextField fx:id="accountFilter" promptText="Filtra cuenta…" minWidth="150" prefWidth="150"/>
                        </buttons>
                    </ButtonBar>
                </HBox>

                <TableView fx:id="tableView" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="tipo_Simul" text="T. Sim" prefWidth="100" visible="false"/>
                        <TableColumn fx:id="detalle_Simultanea" text="Det. Sim" prefWidth="150" visible="false"/>
                        <TableColumn fx:id="ident_Cliente" text="Id CLien." prefWidth="100"/>
                        <TableColumn fx:id="num_Cuenta" text="NC" prefWidth="100"/>
                        <TableColumn fx:id="fecha_Operacion" text="F. Ope" prefWidth="110"/>
                        <TableColumn fx:id="fecha_Vcto" text="F. Ven" prefWidth="110"/>
                        <TableColumn fx:id="nombre_Cliente" text="N Cli" prefWidth="120"/>
                        <TableColumn fx:id="plazo" text="Plazo" prefWidth="80"/>
                        <TableColumn fx:id="plazo_Rem" text="Plazo Rem" prefWidth="100"/>
                        <TableColumn fx:id="nemotecnico" text="Nemo" prefWidth="100"/>
                        <TableColumn fx:id="cantidad" text="Qty" prefWidth="100"/>
                        <TableColumn fx:id="tasa" text="Tasa" prefWidth="100"/>
                        <TableColumn fx:id="precio_PH" text="PX PH" prefWidth="100"/>
                        <TableColumn fx:id="precio_Plazo" text="PX Plazo" prefWidth="100"/>
                        <TableColumn fx:id="precio_Mercado" text="PX Mercado" prefWidth="100"/>
                        <TableColumn fx:id="monto_Contado" text="Monto Contado" prefWidth="100"/>
                        <TableColumn fx:id="costo_Diario2" text="Costo Diario" prefWidth="100"/>
                        <TableColumn fx:id="monto_Presente" text="M Present" prefWidth="100"/>
                        <TableColumn fx:id="monto_Plazo" text="M Plazo" prefWidth="100"/>
                        <TableColumn fx:id="cod_Inst" text="Cod Ins" prefWidth="100" visible="false"/>
                        <TableColumn fx:id="cantidad_Orig" text="Qty Ori" prefWidth="100"/>
                        <TableColumn fx:id="corredor_Venta" text="Vende" prefWidth="130" visible="false"/>
                        <TableColumn fx:id="corredor_Compra" text="Compra" prefWidth="130" visible="false"/>
                        <TableColumn fx:id="folio_Fact_PH" text="F.F.PH" prefWidth="120" visible="false"/>
                        <TableColumn fx:id="folio_Fact_TP" text="F.FAC.TP" prefWidth="120" visible="false"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>
            </children>
        </VBox>

    </children>
</AnchorPane>
