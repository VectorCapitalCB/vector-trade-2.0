<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<AnchorPane xmlns:fx="http://javafx.com/fxml/1" fx:id="anchorPane"
            minHeight="-Infinity" minWidth="-Infinity" pickOnBounds="false"
            prefHeight="610.0" prefWidth="580.0" scaleShape="false"
            xmlns="http://javafx.com/javafx/17.0.2-ea"
            fx:controller="cl.vc.blotter.controller.LoginController"
            style="-fx-background-color: linear-gradient(to bottom, #111317, #191d23);">

    <children>
        <VBox alignment="CENTER" prefHeight="610.0" prefWidth="580.0">
            <children>
                <VBox alignment="TOP_LEFT" maxWidth="360.0" prefWidth="360.0" spacing="14.0"
                      style="-fx-background-color: rgba(26, 30, 36, 0.97); -fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #2e3642; -fx-border-width: 1; -fx-padding: 28 30 24 30;">
                    <children>
                        <Label text="Vector Trade 2.0"
                               style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #e5eaf2;">
                            <font>
                                <Font size="24.0"/>
                            </font>
                        </Label>
                        <Label text="Acceso a Plataforma"
                               style="-fx-font-size: 12px; -fx-text-fill: #9da7b8;"/>

                        <VBox spacing="6.0">
                            <children>
                                <Label text="Usuario"
                                       style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #b9c2d1;"/>
                                <TextField fx:id="txtUsername" prefHeight="34.0" prefWidth="300.0"
                                           promptText="Usuario"
                                           style="-fx-background-color: #21262f; -fx-text-fill: #f4f7fb; -fx-prompt-text-fill: #788395; -fx-border-color: #343d4b; -fx-border-radius: 5; -fx-background-radius: 5;"/>
                            </children>
                        </VBox>

                        <VBox spacing="6.0">
                            <children>
                                <Label text="Contrasena"
                                       style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #b9c2d1;"/>
                                <PasswordField fx:id="password" prefHeight="34.0" prefWidth="300.0"
                                               promptText="Contrasena"
                                               style="-fx-background-color: #21262f; -fx-text-fill: #f4f7fb; -fx-prompt-text-fill: #788395; -fx-border-color: #343d4b; -fx-border-radius: 5; -fx-background-radius: 5;"/>
                                <TextField fx:id="txtPassword" managed="false" prefHeight="34.0" prefWidth="300.0"
                                           promptText="Password" visible="false"/>
                            </children>
                        </VBox>

                        <VBox spacing="6.0">
                            <children>
                                <Label text="Ambiente"
                                       style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #b9c2d1;"/>
                                <ComboBox fx:id="enviroment" id="enviromentLoginCombo" prefHeight="34.0" prefWidth="300.0"
                                          style="-fx-background-color: #21262f; -fx-control-inner-background: #21262f; -fx-border-color: #343d4b; -fx-border-radius: 5; -fx-background-radius: 5; -fx-text-fill: #eef3fb; -fx-mark-color: #eef3fb;"/>
                            </children>
                        </VBox>

                        <CheckBox fx:id="chkGuardarContrasena" text="Guardar usuario y contrasena"
                                  style="-fx-font-weight: bold; -fx-text-fill: #c7d0df; -fx-font-size: 12px;"/>

                        <Button fx:id="btnIngresar" mnemonicParsing="false" onAction="#login" prefHeight="36.0"
                                prefWidth="300.0" styleClass="btn-ingresar-style" text="Ingresar"
                                style="-fx-background-color: linear-gradient(to bottom, #2e4a6d, #22344d); -fx-text-fill: #eaf1fc; -fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #4b6280; -fx-border-width: 1;"/>

                        <HBox fx:id="loading" alignment="CENTER_LEFT">
                            <children>
                                <Label fx:id="label" prefHeight="18.0" text=""
                                       style="-fx-font-size: 11px; -fx-text-fill: #9aa5b5;">
                                    <font>
                                        <Font size="11.0"/>
                                    </font>
                                </Label>
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
