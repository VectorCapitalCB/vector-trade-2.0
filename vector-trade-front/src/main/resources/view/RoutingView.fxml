<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0"
            HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS" xmlns="http://javafx.com/javafx/11.0.14-internal" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="cl.vc.blotter.controller.RoutingController">
    <children>

        <VBox AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0"
              HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">

            <ButtonBar fx:id="ButtonbarFiltros" maxHeight="60" prefHeight="60" HBox.hgrow="ALWAYS">
                <buttons>
                    <Label alignment="BASELINE_RIGHT">Cuenta</Label>
                    <TextField fx:id="accountFilter" minWidth="150" prefWidth="150" promptText="Filtra cuenta…" />
                    <Label alignment="BASELINE_RIGHT">Destino</Label>
                    <ComboBox fx:id="securityExchangeFilter" minWidth="150" prefWidth="150" />
                    <Label alignment="BASELINE_RIGHT">Estado</Label>
                    <ComboBox fx:id="statusFilter" minWidth="150" prefWidth="150" />
                    <Label alignment="BASELINE_RIGHT">Tipo</Label>
                    <ComboBox fx:id="sideFilter" minWidth="150" prefWidth="150" />
                    <Label alignment="BASELINE_RIGHT">Instrumento</Label>
                    <TextField fx:id="symbolFilter" minWidth="150" prefWidth="150" />
                    <CheckBox fx:id="hideIDs" prefHeight="24.0" prefWidth="100" selected="true" style="-fx-font-weight: bold;" text="Ocultar IDs" />
                </buttons>
            </ButtonBar>

            <TabPane fx:id="ruteoTabPane" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS" HBox.hgrow="ALWAYS">
                <Tab fx:id="tabRuteo" text="Trabajando">

                    <VBox spacing="10" VBox.vgrow="ALWAYS" HBox.hgrow="ALWAYS">

                        <ScrollPane fitToHeight="true" fitToWidth="true" VBox.vgrow="ALWAYS">
                            <fx:include fx:id="workingOrder" source="Executions.fxml" />
                        </ScrollPane>

                        <HBox alignment="CENTER" spacing="10" VBox.vgrow="ALWAYS" HBox.hgrow="ALWAYS" >
                            <Button fx:id="best" disable="true" mnemonicParsing="false" onAction="#bestAction2" prefHeight="24.0" prefWidth="60" style="-fx-font-weight: bold;" text="Mejor" />

                            <Button fx:id="hit" disable="true" mnemonicParsing="false" onAction="#hitAction2" prefHeight="24.0" prefWidth="60" style="-fx-font-weight: bold;" text="Agredir" />

                            <Button fx:id="tickMas" disable="true" mnemonicParsing="false" onAction="#tickMas" prefHeight="24.0" prefWidth="55" style="-fx-font-weight: bold;" text="+" />

                            <Button fx:id="tickMenos" disable="true" mnemonicParsing="false" onAction="#tickMenos" prefHeight="24.0" prefWidth="55" style="-fx-font-weight: bold;" text="-" />

                            <Button fx:id="replaceOrder" disable="true" onAction="#replaceOrderAction" prefHeight="24.0" prefWidth="90" style="-fx-font-weight: bold;" styleClass="btn-replaceOrder-style" text="Modificar" HBox.hgrow="ALWAYS">
                        </Button>

                            <Label fx:id="lblquantity" style="-fx-font-weight: bold;" text="Cantidad" />
                            <TextField fx:id="quantity2" prefWidth="90" styleClass="white-background" />

                            <Label fx:id="lblpriceOrder2" style="-fx-font-weight: bold;" text="Precio" />
                            <TextField fx:id="priceOrder2" prefWidth="90" styleClass="white-background" />

                            <Label fx:id="visible" style="-fx-font-weight: bold;" text="Visible %" />
                            <TextField fx:id="visibleid" prefWidth="90" styleClass="white-background" />

                            <Button fx:id="cancelOrder" disable="true" mnemonicParsing="false" onAction="#cancelOrder" prefHeight="24.0" prefWidth="90" styleClass="btn-cancelOrder-style" text="Cancelar" />

                            <Label fx:id="estrategiaLabel" style="-fx-font-weight: bold;" text="Estrategia" />
                            <ComboBox fx:id="estrategia2" prefWidth="120" styleClass="white-background" />

                            <Label fx:id="spreadLabel" style="-fx-font-weight: bold;" text="Spread" />
                            <TextField fx:id="spread2" prefWidth="90" styleClass="white-background" />

                            <Label fx:id="limitLabel" style="-fx-font-weight: bold;" text="Limit" />
                            <TextField fx:id="limit2" prefWidth="90" styleClass="white-background" />

                            <Region HBox.hgrow="ALWAYS" />
                            <Button fx:id="StopAll" mnemonicParsing="false" onAction="#stopAll" prefHeight="24.0" prefWidth="130" styleClass="btn-stop-style" text="Pánico" />

                        </HBox>
                    </VBox>
                </Tab>

                <Tab text="Ejecutadas">
                    <ScrollPane fitToHeight="true" fitToWidth="true" pannable="true">
                        <fx:include fx:id="executionsOrder" source="Executions.fxml" />
                    </ScrollPane>
                </Tab>
            </TabPane>
        </VBox>
    </children>

</AnchorPane>
