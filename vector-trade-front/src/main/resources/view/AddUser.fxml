<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<AnchorPane xmlns:fx="http://javafx.com/fxml/1" fx:id="addusercontroller" prefHeight="427.0" prefWidth="458.0"
            AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0"
            AnchorPane.topAnchor="0.0" xmlns="http://javafx.com/javafx/17.0.2-ea"
            fx:controller="cl.vc.blotter.controller.AddUserController">
    <padding>
        <Insets bottom="10" left="10" right="10" top="10"/>
    </padding>
    <VBox fillWidth="true" maxWidth="200" HBox.hgrow="ALWAYS"/>
    <Button fx:id="btnAceptar" layoutX="34.0" layoutY="386.0" mnemonicParsing="false" onAction="#handleSaveUserAction"
            prefHeight="25.0" prefWidth="83.0" text="Accept"/>
    <Button fx:id="btnCancelar" layoutX="133.0" layoutY="386.0" mnemonicParsing="false" onAction="#handleCancelarAction"
            prefHeight="25.0" prefWidth="83.0" text="Cancel"/>
    <TextField fx:id="txtFirstName" layoutX="25.0" layoutY="65.0" prefHeight="25.0" prefWidth="191.0"/>
    <TextField fx:id="txtLastName" layoutX="236.0" layoutY="65.0" prefHeight="25.0" prefWidth="191.0"/>
    <Label layoutX="25.0" layoutY="43.0" text="First name"/>
    <Label layoutX="238.0" layoutY="43.0" text="Last name"/>
    <TextField fx:id="txtMargin" layoutX="25.0" layoutY="116.0" prefHeight="25.0" prefWidth="191.0"/>
    <TextField fx:id="txtPhone" layoutX="236.0" layoutY="116.0" prefHeight="25.0" prefWidth="191.0"/>
    <Label layoutX="24.0" layoutY="145.0" text="User name"/>
    <TextField fx:id="txtUsername" layoutX="25.0" layoutY="166.0" prefHeight="25.0" prefWidth="191.0"/>
    <TextField fx:id="txtEmail" layoutX="236.0" layoutY="166.0" prefHeight="25.0" prefWidth="191.0"/>
    <Label layoutX="241.0" layoutY="145.0" text="Email"/>
    <Label layoutX="25.0" layoutY="94.0" text="Margin"/>
    <Label layoutX="238.0" layoutY="94.0" text="Phone"/>
    <PasswordField fx:id="txtPassword2" layoutX="25.0" layoutY="216.0" prefHeight="25.0" prefWidth="191.0"/>
    <PasswordField fx:id="txtPassword" layoutX="238.0" layoutY="216.0" prefHeight="25.0" prefWidth="191.0"/>
    <Label layoutX="28.0" layoutY="195.0" text="Password"/>
    <Label layoutX="237.0" layoutY="195.0" text="Confirm Password"/>
    <ComboBox fx:id="cmbGrupos" layoutX="25.0" layoutY="330.0" prefHeight="25.0" prefWidth="191.0"
              promptText="Select a group"/>
    <ComboBox fx:id="cmbGroupDetails" layoutX="236.0" layoutY="330.0" prefHeight="25.0" prefWidth="191.0"/>
    <Label layoutX="33.0" layoutY="309.0" text="Groups"/>
    <Label layoutX="240.0" layoutY="309.0" text="Sub groups"/>
    <TextField fx:id="txtAccount" layoutX="25.0" layoutY="266.0" prefHeight="25.0" prefWidth="191.0"/>
    <Label layoutX="31.0" layoutY="249.0" text="Account"/>
    <Label layoutX="238.0" layoutY="249.0" text="Code Operator"/>
    <TextField fx:id="txtCodeoperator" layoutX="238.0" layoutY="266.0" prefHeight="25.0" prefWidth="191.0"/>
</AnchorPane>
