<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.layout.*?>
<AnchorPane xmlns:fx="http://javafx.com/fxml/1" HBox.hgrow="ALWAYS" xmlns="http://javafx.com/javafx/17.0.2-ea"
            fx:controller="cl.vc.blotter.controller.BasketController">
    <children>
        <VBox AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0"
              AnchorPane.topAnchor="0.0" HBox.hgrow="ALWAYS">
            <children>

                <HBox fx:id="menubasket" spacing="30" minHeight="80" styleClass="black-hbox">
                    <Button fx:id="excelDownload" onAction="#exportBasketsFormat"/>
                    <Button fx:id="basketCopy" onAction="#exportBasketsFormat"/>
                </HBox>

                <TabPane fx:id="tabBasket" tabClosingPolicy="UNAVAILABLE"
                         AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
                         AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0" HBox.hgrow="ALWAYS">

                    <tabs>
                    </tabs>
                </TabPane>


            </children>
        </VBox>
    </children>
</AnchorPane>
