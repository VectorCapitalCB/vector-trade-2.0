<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<AnchorPane xmlns:fx="http://javafx.com/fxml/1"
            SplitPane.resizableWithParent="false"
            xmlns="http://javafx.com/javafx/8.0.112"
            fx:controller="cl.vc.blotter.controller.MarketDataPortfolioViewController" minWidth="750"
            AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0"
            AnchorPane.topAnchor="0.0">
    <children>
        <VBox AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <HBox spacing="20">
                    <padding>
                        <Insets top="10"/>
                    </padding>
                    <VBox.margin>
                        <Insets bottom="10"/>
                    </VBox.margin>
                    <children>

                        <HBox spacing="20" alignment="CENTER_LEFT">
                            <padding><Insets left="10"/></padding>
                            <children>
                                <VBox>
                                    <children>
                                        <Label text="Instrumento">
                                            <VBox.margin><Insets bottom="5"/></VBox.margin>
                                        </Label>
                                        <TextField fx:id="txtSymbol" nodeOrientation="LEFT_TO_RIGHT"
                                                   prefHeight="11.0" prefWidth="80.0" VBox.vgrow="ALWAYS"/>
                                    </children>
                                </VBox>

                                <VBox>
                                    <children>
                                        <Label text="Mercado">
                                            <VBox.margin><Insets bottom="5"/></VBox.margin>
                                        </Label>
                                        <ChoiceBox fx:id="cbMarket" prefWidth="80"/>
                                    </children>
                                </VBox>

                                <VBox>
                                    <children>
                                        <Label text="Liquidación">
                                            <VBox.margin><Insets bottom="5"/></VBox.margin>
                                        </Label>
                                        <ChoiceBox fx:id="settlType" prefWidth="80"/>
                                    </children>
                                </VBox>

                                <VBox>
                                    <children>
                                        <Label text="Clase">
                                            <VBox.margin><Insets bottom="5"/></VBox.margin>
                                        </Label>
                                        <ChoiceBox fx:id="securityType" prefWidth="80"/>
                                    </children>
                                </VBox>

                                <VBox>
                                    <children>
                                        <Label text=""><VBox.margin><Insets bottom="5"/></VBox.margin></Label>
                                        <Button onAction="#addSymbol" prefHeight="35" prefWidth="90" text="Agregar"/>
                                    </children>
                                </VBox>

                                <VBox>
                                    <children>
                                        <Label text=""><VBox.margin><Insets bottom="5"/></VBox.margin></Label>
                                        <Button fx:id="removeSymbol" onAction="#removeSymbol" prefHeight="35"
                                                prefWidth="90" text="Remover"/>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                        <Region prefWidth="50" HBox.hgrow="ALWAYS"/>
                        <HBox spacing="20" alignment="CENTER_RIGHT">
                            <padding><Insets right="10"/></padding>
                            <children>
                                <Button fx:id="removePortafolio"
                                        onAction="#deletePorfolio"
                                        prefHeight="35" prefWidth="140"
                                        text="Eliminar Portafolio"/>
                            </children>
                        </HBox>

                    </children>
                </HBox>



                <AnchorPane VBox.vgrow="ALWAYS" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
                            AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                    <children>

                        <TableView fx:id="marketDataStatisticsTable" layoutX="34.0" AnchorPane.bottomAnchor="0.0"
                                   AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                            <columns>
                                <TableColumn fx:id="symbol" prefWidth="65" text="Instrumento"/>
                                <TableColumn fx:id="settlTypeCol" prefWidth="30" text="Condición"/>
                                <TableColumn fx:id="imbalanceGen" prefWidth="40" text="Var %" visible="true"/>
                                <TableColumn fx:id="market" prefWidth="55" text="Mercado"/>
                                <TableColumn fx:id="bidQtyGen" prefWidth="65" text="Qty Compra"/>
                                <TableColumn fx:id="bidpriceGen" prefWidth="65" text="Px Compra"/>
                                <TableColumn fx:id="offerpriceGen" prefWidth="65" text="Px Venta"/>
                                <TableColumn fx:id="offerQtyGen" prefWidth="65" text="Qty Venta"/>
                                <TableColumn fx:id="openpriceGen" prefWidth="65" text="Apertura" visible="false"/>
                                <TableColumn fx:id="closepriceGen" prefWidth="65" text="Ultimo"/>
                                <TableColumn fx:id="highpriceGen" prefWidth="65" text="Mayor"/>
                                <TableColumn fx:id="lowpriceGen" prefWidth="65" text="Menor" visible="false"/>
                                <TableColumn fx:id="amountGen" prefWidth="95" text="Monto"/>
                                <TableColumn fx:id="volumeGen" prefWidth="65" text="Volumen"/>
                                <TableColumn fx:id="vwapGen" prefWidth="50.0" text="VWAP" visible="false"/>
                                <TableColumn fx:id="desbalancetheoric" prefWidth="75" text="Desbalance teórico"/>
                                <TableColumn fx:id="priceTheoric" prefWidth="75" text="Precio teórico"/>
                                <TableColumn fx:id="amountTheoric" prefWidth="75" text="Monto teórico"/>
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                            </columnResizePolicy>
                        </TableView>
                    </children>
                </AnchorPane>
                <TitledPane fx:id="tbNews" text="News" visible="false" managed="false">
                    <content>
                        <HBox fx:id="newsHBox" spacing="10" visible="false" managed="false"/>
                    </content>
                </TitledPane>

            </children>
        </VBox>
    </children>
</AnchorPane>
