<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane fx:id="lanzadorController" HBox.hgrow="ALWAYS" xmlns="http://javafx.com/javafx/11.0.14-internal"
            xmlns:fx="http://javafx.com/fxml/1" fx:controller="cl.vc.blotter.controller.LanzadorController">

        <VBox fx:id="myHBox" spacing="10" HBox.hgrow="ALWAYS">

            <VBox fx:id="vboxNemo" prefHeight="0.0" prefWidth="682.0" spacing="10"
                  style="-fx-padding: 10px 10px 10px 10px;"> <!-- Añadir padding al VBox -->

                <HBox spacing="1">
                    <Label fx:id="lblSerach" style="-fx-font-weight: bold;" text="Buscar Instrumento" />
                    <Pane fx:id="pane9" minWidth="435" />
                    <Label fx:id="labelBroker" style="-fx-font-weight: bold;" text="Bróker" />
                </HBox>

                <!-- Aquí agregamos margen y espaciado entre los controles -->
                <HBox prefHeight="25.0" prefWidth="95.0" spacing="5" style="-fx-padding: 0px 0px 0px 0px;"> <!-- Padding izquierdo para el HBox -->
                    <StackPane fx:id="stackPane">
                        <TextField fx:id="ticket" prefWidth="120" styleClass="ticket" />
                        <Label fx:id="searchIconLabel" styleClass="search-icon-label">
                        </Label>
                    </StackPane>
                    <Pane fx:id="pane7" minWidth="3" />
                    <Button fx:id="addBookButton"  prefWidth="118" onAction="#addBook" styleClass="add-book-button" text="Agregar Libro">
                    </Button>
                    <Button fx:id="addpreselect" onAction="#preSelectAction" prefHeight="24.0" prefWidth="108" style="-fx-font-weight: bold;" text="Pre-Digitadas" />
                    <Button fx:id="paste" prefHeight="24.0" prefWidth="100" style="-fx-font-weight: bold;" text="Paste Order" />
                    <Pane fx:id="pane8" minWidth="99" />
                    <ComboBox fx:id="brokerOrder" prefHeight="25.0" prefWidth="120" promptText="Seleccione" styleClass="white-background" visible="true" />
                </HBox>
            </VBox>

            <GridPane fx:id="gpLauncher" alignment="CENTER" hgap="15" style="-fx-padding: 0px 0px 0px 10px;" vgap="8" HBox.hgrow="ALWAYS">
                <!-- LINEA 1 -->
                <VBox fx:id="vboxTipoOrden" spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="1">
                    <Label style="-fx-font-weight: bold;" text="Tipo de Orden" />
                    <ComboBox fx:id="sideOrder" prefWidth="120" styleClass="white-background" />
                </VBox>

                <VBox fx:id="vboxCantidad" spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="1">
                    <Label style="-fx-font-weight: bold;" text="Cantidad" />
                    <TextField fx:id="quantity" prefWidth="120" styleClass="white-background" />
                </VBox>

                <VBox fx:id="vboxPrecio" spacing="5" GridPane.columnIndex="2" GridPane.rowIndex="1">
                    <Label style="-fx-font-weight: bold;" text="Precio" />
                    <TextField fx:id="priceOrder" prefWidth="120" styleClass="white-background" />
                </VBox>

                <VBox fx:id="VboxCash" spacing="5" GridPane.columnIndex="3" GridPane.rowIndex="1">
                    <Label style="-fx-font-weight: bold;" text="Monto" />
                    <TextField fx:id="cash" disable="true" prefWidth="120" styleClass="white-background" />
                </VBox>

                <VBox fx:id="VboxTmoneda" spacing="5" GridPane.columnIndex="4" GridPane.rowIndex="1">
                    <Label fx:id="currencylb" style="-fx-font-weight: bold;" text="Tipo Moneda" />
                    <ComboBox fx:id="currency" prefWidth="120" styleClass="white-background" />
                </VBox>

                <!-- LINEA 2 -->

                <VBox fx:id="VboxLiquidacion" spacing="5" GridPane.columnIndex="3" GridPane.rowIndex="2">
                    <Label fx:id="lblsettltypeOrder" style="-fx-font-weight: bold;" text="Liquidación" />
                    <ComboBox fx:id="settltypeOrder" prefWidth="120" styleClass="white-background" />
                </VBox>

                <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="2">
                    <Label style="-fx-font-weight: bold;" text="Visible %" />
                    <TextField fx:id="iceberg" prefWidth="120" styleClass="white-background" />
                </VBox>

                <VBox fx:id="VboxSecurityType" spacing="5" GridPane.columnIndex="2" GridPane.rowIndex="2">
                    <Label fx:id="LblsecurityType" style="-fx-font-weight: bold;" text="Clase" />
                    <ComboBox fx:id="securityType" disable="false" prefWidth="120" styleClass="white-background" />
                </VBox>

                <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="2">
                    <Label fx:id="LblacAccount" style="-fx-font-weight: bold;" text="Cuenta" />
                    <ComboBox fx:id="acAccount" prefWidth="120" styleClass="white-background" />
                </VBox>

                <VBox fx:id="VboxEstrategia" spacing="5" GridPane.columnIndex="4" GridPane.rowIndex="2">
                    <Label fx:id="strategylb" style="-fx-font-weight: bold;" text="Estrategia" />
                    <ComboBox fx:id="strategOrder" prefWidth="120" styleClass="white-background" />
                </VBox>

                <!-- LINEA 3 -->

                <VBox fx:id="VboxCodOperador" spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="3">
                    <Label fx:id="cOperadorlb" style="-fx-font-weight: bold;" text="Cod. Operador" />
                    <ComboBox fx:id="cOperador" disable="false" prefWidth="120" styleClass="white-background" />
                </VBox>

                <VBox fx:id="VboxTipo" spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="3">
                    <Label fx:id="tipo" style="-fx-font-weight: bold;" text="Tipo" />
                    <ComboBox fx:id="typeOrder" prefWidth="120" styleClass="white-background" />
                </VBox>

                <VBox fx:id="VboxSpread" spacing="5" GridPane.columnIndex="2" GridPane.rowIndex="3">
                    <Label fx:id="spreadlb" style="-fx-font-weight: bold;" text="Spread (PX)" />
                    <TextField fx:id="spread" disable="true" prefWidth="120" styleClass="white-background" />
                </VBox>

                <VBox fx:id="VboxLimit" spacing="5" GridPane.columnIndex="3" GridPane.rowIndex="3">
                    <Label fx:id="limitlb" style="-fx-font-weight: bold;" text="Limit (PX)" />
                    <TextField fx:id="limit" disable="true" prefWidth="120" styleClass="white-background" />
                </VBox>

                <VBox fx:id="VboxSecExc" spacing="5" GridPane.columnIndex="4" GridPane.rowIndex="3">
                    <Label fx:id="secLb" style="-fx-font-weight: bold;" text="Sec. Exch" />
                    <ComboBox fx:id="secExchOrder" prefWidth="120" styleClass="white-background" />
                </VBox>


                <VBox fx:id="vboxTimeEffective" spacing="5" GridPane.columnIndex="3" GridPane.rowIndex="5">
                    <Label style="-fx-font-weight: bold;" text="Minutos / Hora Inicio" />
                    <HBox>
                        <Spinner fx:id="slice" prefWidth="51"/>
                        <Spinner fx:id="hourSpinnerEffective" prefWidth="51"/>
                        <Spinner fx:id="minuteSpinnerEffective" prefWidth="51"/>
                    </HBox>
                </VBox>

                <VBox  fx:id="vboxTimeExpire" spacing="5" GridPane.columnIndex="4" GridPane.rowIndex="5">
                    <Label style="-fx-font-weight: bold;" text="Hora Termino" />
                    <HBox>
                        <Spinner fx:id="hourSpinnerExpire" prefWidth="51"/>
                        <Spinner fx:id="minuteSpinnerExpire" prefWidth="51"/>

                    </HBox>
                </VBox>

         <columnConstraints>
            <ColumnConstraints />
            <ColumnConstraints />
            <ColumnConstraints />
            <ColumnConstraints />
            <ColumnConstraints />
         </columnConstraints>
         <rowConstraints>
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
         </rowConstraints>
            </GridPane>

            <VBox fx:id="ContenedorGrid" spacing="10" style="-fx-padding: 20px 0px 0px 16px;" VBox.vgrow="ALWAYS">

                <HBox spacing="5">
                    <Button fx:id="routeOrder" onAction="#routeOrder" prefHeight="25.0" prefWidth="120" style="-fx-font-weight: bold;" text="Enviar" />
                    <Pane fx:id="pane1" minWidth="20" />
                    <Button fx:id="bestR" onAction="#bestAction" prefHeight="24.0" prefWidth="75" style="-fx-font-weight: bold;" text="Mejor" />
                    <Button fx:id="hitR" onAction="#hitAction" prefHeight="24.0" prefWidth="75" style="-fx-font-weight: bold;" text="Agredir" />
                    <Pane fx:id="pane2" minWidth="28.0" prefHeight="25.0" prefWidth="28.0" />
                    <Button fx:id="clean" onAction="#cleanform" prefHeight="24.0" prefWidth="100" style="-fx-font-weight: bold;" text="Limpiar" />
                    <Pane fx:id="pane3" minWidth="5" />
                    <Button fx:id="unlock" prefHeight="24.0" prefWidth="10" style="-fx-font-weight: bold;" text="Desbloquear" visible="false" />
                    <Pane fx:id="pane4" minWidth="50" />
                    <Label fx:id="lblAgreement" text="OPCI" />
                    <CheckBox fx:id="chkIndivisible" onAction="#handleAgreeAction" prefHeight="24.0" prefWidth="110" selected="true" text="Indivisible" VBox.vgrow="ALWAYS" />

                    <Label managed="false" style="-fx-font-weight: bold;" text="Broker" visible="false" />
                    <ComboBox managed="false" prefWidth="120" promptText="Seleccione" styleClass="white-background" visible="false" />
                    <Label managed="false" style="-fx-font-weight: bold;" text="HandInst" visible="false" />
                    <ComboBox fx:id="handInstOrder" managed="false" prefWidth="120" styleClass="white-background" visible="false" />
                    <Label managed="false" style="-fx-font-weight: bold;" text="TIF" visible="false" />
                    <ComboBox fx:id="tifOrder" managed="false" prefWidth="120" styleClass="white-background" visible="false" />
                </HBox>
            </VBox>
        </VBox>
</AnchorPane>
