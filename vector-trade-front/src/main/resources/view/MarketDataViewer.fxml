<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns:fx="http://javafx.com/fxml/1" AnchorPane.bottomAnchor="0.0"
            AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0"
            xmlns="http://javafx.com/javafx/17.0.2-ea" fx:controller="cl.vc.blotter.controller.MarketDataViewerController">
    <padding>
        <Insets bottom="10" left="10" right="10" top="10"/>
    </padding>
    <children>
        <VBox fillWidth="true" spacing="10" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0"
              AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">

            <HBox spacing="10" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">

                <fx:include fx:id="lanzador" source="Lanzador.fxml"/>

                <SplitPane fx:id="Splid" dividerPositions="0.0" prefHeight="400" prefWidth="350" HBox.hgrow="ALWAYS"
                           VBox.vgrow="ALWAYS" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0"
                           AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
                    <items>
                        <HBox fx:id="hboxMKD" prefWidth="240" minWidth="240" maxWidth="240"  alignment="TOP_LEFT" maxHeight="Infinity"  spacing="5"
                              HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">
                        </HBox>
                        <TabPane fx:id="tabpanel" prefWidth="500" side="RIGHT" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">
                            <Tab fx:id="tabmkd" closable="false" text="Datos del Mercado">
                                <ScrollPane fitToHeight="true" fitToWidth="true" HBox.hgrow="ALWAYS"
                                            VBox.vgrow="ALWAYS">
                                    <content>
                                        <HBox maxHeight="Infinity" maxWidth="Infinity" spacing="5" HBox.hgrow="ALWAYS"
                                              VBox.vgrow="ALWAYS">
                                            <TitledPane fx:id="titelpaneMarketData" animated="false" collapsible="false"
                                                        text="Últimas Operaciones Nemo" HBox.hgrow="ALWAYS"
                                                        VBox.vgrow="ALWAYS">
                                                <TableView fx:id="marketDataTradeTable" maxWidth="Infinity"
                                                           prefWidth="480.0" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">
                                                    <columns>
                                                        <TableColumn fx:id="time" sortType="DESCENDING" text="Tiempo"/>
                                                        <TableColumn fx:id="priceTrade" text="Precio"/>
                                                        <TableColumn fx:id="qtyTrade" text="Cantidad"/>
                                                        <TableColumn fx:id="symboltrades" text="Instrumento"/>
                                                        <TableColumn fx:id="buyer" text="Comprador"/>
                                                        <TableColumn fx:id="seller" text="Vendedor"/>
                                                        <TableColumn fx:id="idgenerado" text="id" minWidth="150" visible="false"/>
                                                    </columns>
                                                </TableView>
                                            </TitledPane>

                                            <TitledPane fx:id="titelpaneMarketDataMercadoGeneral" animated="false"
                                                        collapsible="false" text="Últimas Operaciones"
                                                        HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">
                                                <TableView fx:id="marketDataTradeTableG" HBox.hgrow="ALWAYS"
                                                           VBox.vgrow="ALWAYS">
                                                    <columns>
                                                        <TableColumn fx:id="timeG" sortType="DESCENDING" text="Tiempo"/>
                                                        <TableColumn fx:id="priceTradeG" text="Precio"/>
                                                        <TableColumn fx:id="qtyTradeG" text="Cantidad"/>
                                                        <TableColumn fx:id="symboltradesG" text="Instrumento"/>
                                                        <TableColumn fx:id="buyerG" text="Comprador"/>
                                                        <TableColumn fx:id="selleG" text="Vendedor"/>
                                                        <TableColumn fx:id="idgeneradoG" text="id" minWidth="150" visible="false"/>
                                                    </columns>
                                                </TableView>
                                            </TitledPane>
                                        </HBox>
                                    </content>
                                </ScrollPane>
                            </Tab>

                            <Tab closable="false" text="Pre-Digitados">
                                <content>
                                    <VBox>
                                        <fx:include fx:id="preselectOrders" source="Executions.fxml"/>
                                    </VBox>
                                </content>
                            </Tab>

                            <!--Tab closable="false" text="Graficos">
                                <content>
                                    <VBox>
                                        <fx:include fx:id="grafico" source="GraficoView.fxml"/>
                                    </VBox>
                                </content>
                            </Tab-->

                        </TabPane>
                    </items>
                </SplitPane>
            </HBox>
            <HBox fx:id="containerbajo" prefHeight="890" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
                  AnchorPane.rightAnchor="0.0" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">
                <TabPane fx:id="mkd" nodeOrientation="LEFT_TO_RIGHT" tabClosingPolicy="UNAVAILABLE" HBox.hgrow="ALWAYS"
                         VBox.vgrow="ALWAYS">
                    <Tab fx:id="tabmkd2" text="Datos del Mercado">
                        <content>
                            <TabPane fx:id="tpMkData" nodeOrientation="LEFT_TO_RIGHT" tabClosingPolicy="UNAVAILABLE"
                                     VBox.vgrow="ALWAYS">
                                <Tab fx:id="add" closable="false" text="+"/>
                            </TabPane>
                        </content>
                    </Tab>
                    <Tab fx:id="orderlauncher" text="Ruteo">
                        <content>
                            <VBox VBox.vgrow="ALWAYS">
                                <ButtonBar fx:id="ButtonbarFiltros" maxHeight="60" prefHeight="60" HBox.hgrow="ALWAYS">
                                    <buttons>
                                        <Label alignment="BASELINE_RIGHT">Cuenta</Label>
                                        <TextField fx:id="accountFilter" promptText="Filtra cuenta…" minWidth="150" prefWidth="150"/>
                                        <Label alignment="BASELINE_RIGHT">Destino</Label>
                                        <ComboBox fx:id="securityExchangeFilter" minWidth="150" prefWidth="150"/>
                                        <Label alignment="BASELINE_RIGHT">Estado</Label>
                                        <ComboBox fx:id="statusFilter" minWidth="150" prefWidth="150"/>
                                        <Label alignment="BASELINE_RIGHT">Tipo</Label>
                                        <ComboBox fx:id="sideFilter" minWidth="150" prefWidth="150"/>
                                        <Label alignment="BASELINE_RIGHT">Instrumento</Label>
                                        <TextField fx:id="symbolFilter" minWidth="150" prefWidth="150"/>
                                        <CheckBox fx:id="hideIDs" prefHeight="24.0" prefWidth="100" selected="true" style="-fx-font-weight: bold;" text="Ocultar IDs"/>
                                    </buttons>
                                </ButtonBar>
                                <TabPane fx:id="ruteoTabPane" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
                                    <Tab fx:id="tabRuteo" text="Trabajando">
                                        <VBox spacing="10" VBox.vgrow="ALWAYS">
                                            <ScrollPane fitToHeight="true" fitToWidth="true" VBox.vgrow="ALWAYS">
                                                <fx:include fx:id="workingOrder" source="Executions.fxml"/>
                                            </ScrollPane>

                                            <HBox alignment="CENTER" spacing="10" VBox.vgrow="NEVER">
                                                <Button fx:id="best" disable="true" mnemonicParsing="false"
                                                        onAction="#bestAction2" prefHeight="24.0" prefWidth="60"
                                                        style="-fx-font-weight: bold;" text="Mejor"/>

                                                <Button fx:id="hit" disable="true" mnemonicParsing="false"
                                                        onAction="#hitAction2" prefHeight="24.0" prefWidth="60"
                                                        style="-fx-font-weight: bold;" text="Agredir"/>

                                                <Button fx:id="tickMas" disable="true" mnemonicParsing="false"
                                                        onAction="#tickMas" prefHeight="24.0" prefWidth="55"
                                                        style="-fx-font-weight: bold;" text="+"/>

                                                <Button fx:id="tickMenos" disable="true" mnemonicParsing="false"
                                                        onAction="#tickMenos" prefHeight="24.0" prefWidth="55"
                                                        style="-fx-font-weight: bold;" text="-"/>

                                                <Button fx:id="replaceOrder" disable="true"
                                                        onAction="#replaceOrderAction" prefHeight="24.0" prefWidth="90"
                                                        style="-fx-font-weight: bold;"
                                                        styleClass="btn-replaceOrder-style" text="Modificar"/>

                                                <Label fx:id="lblquantity" style="-fx-font-weight: bold;"
                                                       text="Cantidad"/>
                                                <TextField fx:id="quantity2" prefWidth="90"
                                                           styleClass="white-background"/>

                                                <Label fx:id="lblpriceOrder2" style="-fx-font-weight: bold;"
                                                       text="Precio"/>
                                                <TextField fx:id="priceOrder2" prefWidth="90"
                                                           styleClass="white-background"/>

                                                <Label fx:id="visible" style="-fx-font-weight: bold;" text="Visible %"/>
                                                <TextField fx:id="visibleid" prefWidth="90"
                                                           styleClass="white-background"/>

                                                <Button fx:id="cancelOrder" disable="true" mnemonicParsing="false"
                                                        onAction="#cancelOrder" prefHeight="24.0" prefWidth="90"
                                                        styleClass="btn-cancelOrder-style" text="Cancelar"/>

                                                <Label fx:id="estrategiaLabel" style="-fx-font-weight: bold;"
                                                       text="Estrategia"/>
                                                <ComboBox fx:id="estrategia2" prefWidth="120"
                                                          styleClass="white-background"/>

                                                <Label fx:id="spreadLabel" style="-fx-font-weight: bold;"
                                                       text="Spread"/>
                                                <TextField fx:id="spread2" prefWidth="90"
                                                           styleClass="white-background"/>

                                                <Label fx:id="limitLabel" style="-fx-font-weight: bold;" text="Limit"/>
                                                <TextField fx:id="limit2" prefWidth="90" styleClass="white-background"/>

                                                <Region HBox.hgrow="ALWAYS"/>
                                                <Button fx:id="StopAll" mnemonicParsing="false" onAction="#stopAll"
                                                        prefHeight="24.0" prefWidth="130" styleClass="btn-stop-style"
                                                        text="Pánico"/>
                                            </HBox>
                                        </VBox>
                                    </Tab>
                                    <Tab text="Ejecutadas">
                                        <ScrollPane fitToHeight="true" fitToWidth="true" pannable="true">
                                            <fx:include fx:id="executionsOrder" source="Executions.fxml"/>
                                        </ScrollPane>
                                    </Tab>
                                </TabPane>
                            </VBox>
                        </content>
                    </Tab>
                    <Tab text="Posiciones">
                        <fx:include fx:id="positionsView" source="PositionsView.fxml"/>
                    </Tab>
                </TabPane>
            </HBox>
        </VBox>
    </children>
</AnchorPane>
